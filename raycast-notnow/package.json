{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "notnow-url-search",
  "title": "NotNow URL Search",
  "description": "Independent NotNow Raycast extension with URL-first grouped search and highlighted tags.",
  "icon": "assets/notnow.png",
  "author": "shadow",
  "categories": [
    "Productivity",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-notnow-url",
      "title": "Search NotNow URL",
      "subtitle": "Grouped, URL-first",
      "description": "Search NotNow data by URL only, grouped by kind, prioritizing non-x.com results.",
      "mode": "view",
      "icon": "assets/notnow.png",
      "preferences": [
        {
          "name": "storePath",
          "type": "textfield",
          "required": false,
          "title": "Store Path",
          "description": "SQLite path of NotNow store",
          "placeholder": "~/Library/Application Support/default.store"
        },
        {
          "name": "maxResults",
          "type": "textfield",
          "required": false,
          "title": "Max Results",
          "description": "Final number of displayed results after grouping/sorting",
          "default": "200",
          "placeholder": "200"
        },
        {
          "name": "showXDomain",
          "type": "checkbox",
          "required": false,
          "title": "Include x.com Results",
          "label": "Show x.com links (kept lower priority)",
          "default": true
        }
      ]
    }
  ],
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix"
  },
  "dependencies": {
    "@raycast/api": "^1.80.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
